{
  "root": false,
  "env": {
    "node": true,
    "es2022": true,
    "serviceworker": true
  },
  "globals": {
    "AURA_DEBUG": "readonly",
    "AbortSignal": "readonly"
  },
  "extends": ["eslint:recommended"],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "rules": {
    "no-unused-vars": "warn",
    "no-console": "warn"
  }
}
